# API-Football (api-sports.io) — free tier at https://dashboard.api-football.com
# The key is read only on the server (Next.js route handlers); it never reaches the browser.
API_FOOTBALL_KEY=your_key_here

# Optional. Direct api-sports.io host is the default.
# If you access API-Football through the RapidAPI gateway instead, set this to
# api-football-v1.p.rapidapi.com and the app will send RapidAPI auth headers.
# API_FOOTBALL_HOST=v3.football.api-sports.io

# Optional. Season year for stats lookups. Defaults to 2023 (broad free-tier
# coverage); the app falls back to the previous season if that returns nothing.
# API_FOOTBALL_SEASON=2023
